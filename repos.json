        "service_account":"sa-a",
        "image_name":     "image-a"
      }
    },
    {
      "name": "app-b",
      "repo": "your-org/app-b-deploy",
      "substitutions": {
        "app_name":       "app-b",
        "namespace":      "ns-b",
        "service_account":"sa-b",
        "image_name":     "image-b"
      }
    }
  ]
}
